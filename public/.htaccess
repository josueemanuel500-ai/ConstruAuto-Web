# ============================================================
# ConstruAuto de México — configuración de hosting (Apache)
# Sube este archivo junto al resto del contenido de dist/ a
# la raíz de public_html.
# ============================================================

RewriteEngine On

# ---- 1) Forzar HTTPS y el subdominio www (una sola URL para Google) ----
# IMPORTANTE: descomenta estas 3 líneas (RewriteCond/RewriteCond/RewriteRule) solo
# cuando el certificado SSL ya esté activo y funcionando en tu hosting. Con el SSL
# roto, este redirect deja el sitio inaccesible.
# RewriteCond %{HTTPS} off [OR]
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

# ---- 2) Cabeceras de seguridad ----
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  # Descomenta la siguiente línea solo cuando el SSL ya esté activo:
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ---- 3) Anti-hotlinking de imágenes (otros sitios no pueden mostrarlas) ----
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?construautodemexico\.com\.mx [NC]
  RewriteRule \.(jpe?g|png|gif|webp)$ - [F,NC]
</IfModule>

# ---- 4) Bloqueo de archivos sensibles ----
<FilesMatch "^(\.env.*|\.htaccess|\.git.*|.*\.log)$">
  Require all denied
</FilesMatch>

# ---- 5) Compresión ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---- 6) Caché de archivos estáticos ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
